class Student10
{
    String name;
    int marks;
    static String college = "Jspider";

    void display()
    {
        System.out.println("Name: " + name);
        System.out.println("Marks: " + marks);
        System.out.println("College: " + college);
    }

    public static void main(String[] args)
    {
        Student10 s1 = new Student10();
        s1.name = "Saroja";
        s1.marks = 95;
        s1.display();
    }
}
